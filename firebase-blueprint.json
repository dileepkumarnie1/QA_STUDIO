{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A software testing project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "prompt": { "type": "string" },
        "templateId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "prompt", "createdAt", "updatedAt", "userId"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a project chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User projects"
    },
    "/projects/{projectId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a project"
    }
  }
}
