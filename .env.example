# ── Server-side (required) ────────────────────────────────────────────────────
# Gemini API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Port the Express server listens on (defaults to 3001 in dev, set by host in prod)
PORT=3001

# ── Firebase Admin — production token verification (optional but recommended) ─
# Paste the full JSON contents of your Firebase service account key here.
# Generate from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Leave blank to run in dev mode (token verification skipped, Firestore rules still enforced).
FIREBASE_SERVICE_ACCOUNT_JSON=''

# ── Firebase client config ────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_WEB_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="qa-studio-37f60.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="qa-studio-37f60"
VITE_FIREBASE_STORAGE_BUCKET="qa-studio-37f60.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"

# Optional — only set if using a non-default Firestore database ID
VITE_FIREBASE_DATABASE_ID=""

# ── Access control (optional) ─────────────────────────────────────────────────
# Comma-separated list of allowed email addresses. Leave blank to allow all Google accounts.
VITE_ALLOWED_EMAILS=""
